# ============================================================
# BODC Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Server
NODE_ENV=development
PORT=3001

# Database (Railway PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host:5432/bodc_db

# JWT Secrets — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_with_random_64_char_string
JWT_REFRESH_SECRET=replace_with_different_random_64_char_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer — use Gmail app password or SendGrid/Resend for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=BODC <noreply@bodc.app>

# File uploads (optional — for logo and photo uploads)
# Leave blank to skip file upload support in dev
UPLOAD_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# Logging
LOG_LEVEL=info

# Copy to .env.local for local development
# In Vercel, set REACT_APP_API_URL in project settings

# Your Railway backend URL (no trailing slash)
REACT_APP_API_URL=https://your-app.railway.app/api

# Optional: VAPID public key for push notifications
# REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key_here
